%% 5. Batch Epoching for TST Data

% Author: Røskva
% Date: 18.12.25
% Last changed: 12.03.26

% Workflow:
% Step 1. Preprocess EEG + ICA
% Step 2. Manually reject ICs
% Step 3. Map logfiles onto EEG events
% Step 4. Extract behavioural overview
% Step 5. Epoch data (this script)

% PURPOSE:
% Create stimulus-locked epochs for all task trials while preserving
% metadata fields (switch/repeat, congruency, outcome etc.).
% Artifact epochs are detected but only marked, not removed.

% Epoch window: -1500 ms to +1500 ms
% Artifact detection: ±100 µV
% Baseline correction will be applied later during time–frequency analysis.


%% 0. Initialize EEGLAB and set paths

addpath('\\hypatia.uio.no\...\eeglab2025.0.0\', ...
        '\\hypatia.uio.no\...\Røskva\', ...
        '\\hypatia.uio.no\...\Røskva\Code\');

eeglab;  % Start EEGLAB


%% 1. Define folders

mapped_folder = '\\hypatia.uio.no\...\3_mapped\';
out_folder    = '\\hypatia.uio.no\...\4_epoched\';

if ~exist(out_folder, 'dir')
    mkdir(out_folder);
end


%% 2. Load dataset (single participant test)

filename = 'TST_33_1_cleaned_mapped.set';

EEG = pop_loadset('filename', filename, 'filepath', mapped_folder);
[ALLEEG, EEG, CURRENTSET] = eeg_store(ALLEEG, EEG, 0);

[~, base_name, ~] = fileparts(filename);

disp(['Epoching dataset: ' base_name]);


%% 3. Identify stimulus events (LET* or NUM*)

types = {EEG.event.type};

stimMask = startsWith(types, 'LET') | startsWith(types, 'NUM');

stimEvents = unique(types(stimMask));

disp('Stimulus event types detected:');
disp(stimEvents');


%% 4. Epoch around stimulus events

EEG = pop_epoch(EEG, stimEvents, [-1.5 1.5], ...
    'newname', [base_name '_epoched'], ...
    'epochinfo', 'yes');

[ALLEEG, EEG, CURRENTSET] = pop_newset(ALLEEG, EEG, 1, 'gui', 'off');


%% 5. Detect high-amplitude artifacts (mark only)

EEG = pop_eegthresh(EEG, 1, ...
    1:EEG.nbchan, ...   % all channels
    -100, 100, ...      % amplitude threshold
    -1.5, 1.5, ...      % time window
    0, 0);              % mark but do not reject

nMarked = sum(EEG.reject.rejthresh);

disp(['Epochs marked for potential artifact: ' num2str(nMarked)]);


%% 6. Save epoched dataset

out_filename = [base_name '_epoched.set'];

pop_saveset(EEG, 'filename', out_filename, 'filepath', out_folder);

disp(['SUCCESS: epoched dataset saved as ' out_filename]);


disp('Epoching test complete.');
