import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

# --- LOAD ---
df = pd.read_csv(
    r"C:\Users\roskvatb\...\sleep_daily.csv",
    sep=';'
)
print(df.columns)


# optional: ensure ordering by ID
df['ID'] = df['ID'].astype(str)

# --- PLOT ---
plt.figure(figsize=(14,6))

# boxplot
sns.boxplot(
    data=df,
    x='ID',
    y='TST_h',
    color='lightgray',
    showfliers=False
)

# strip plot (dots)
sns.stripplot(
    data=df,
    x='ID',
    y='TST_h',
    color='black',
    size=3,
    jitter=True,
    alpha=0.6
)

plt.xticks(rotation=90)
plt.xlabel("Participant")
plt.ylabel("TST (hours)")
plt.title("Total Sleep Time per Participant (14 days pre-EEG)")

plt.tight_layout()
plt.show()
