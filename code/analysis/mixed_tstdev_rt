%% Script: MIXED_MODEL_TSTDEV_RT

% Author: Røskva 
% Created: 07.04.2026
% Modified: 23.04.2026

% Purpose:
% Examine whether night-to-night sleep deviation predicts reaction times
% across task conditions using a linear mixed-effects model.

% Input:
% data_merged_sleep_behaviour.csv
% (participant-level dataset containing behavioural measures and sleep variables)

% Output:
% mixed_model_sleep_RT.mat
% mixed_model_sleep_RT_results.txt

% Variables:
% Dependent variable:
% - RT (reaction time per condition, correct trials)

% Fixed effects:
% - TST_dev (night-before deviation from mean sleep)
% - Switch (repeat vs switch)
% - Congruency (congruent vs incongruent)
% - Interactions between sleep deviation and task factors

% Random effects:
% - Random intercept for participant (ID)

% Notes:
% Data are reshaped into long format (one row per participant × condition).
% This model tests whether night-before sleep deviation is associated
% with changes in cognitive control performance, including flexibility
% (Switch) and stability (Congruency) effects.

clear; clc;

%% 1. Load data
data = readtable('\\hypatia.uio.no\...\data_merged_sleep_behaviour.csv');

%% 2. Remove missing values
keep = ~isnan(data.TST_dev) & ...
       ~isnan(data.rt_cC_rp_con) & ~isnan(data.rt_cC_rp_inc) & ...
       ~isnan(data.rt_cC_sw_con) & ~isnan(data.rt_cC_sw_inc);

data = data(keep,:);

fprintf('Merged N (RT + TST_dev): %d\n', height(data));

%% 3. Create long format
ID = [data.ID; data.ID; data.ID; data.ID];

RT = [
    data.rt_cC_rp_con
    data.rt_cC_rp_inc
    data.rt_cC_sw_con
    data.rt_cC_sw_inc
];

Switch = categorical([
    repmat("repeat", height(data),1)
    repmat("repeat", height(data),1)
    repmat("switch", height(data),1)
    repmat("switch", height(data),1)
]);

Congruency = categorical([
    repmat("congruent", height(data),1)
    repmat("incongruent", height(data),1)
    repmat("congruent", height(data),1)
    repmat("incongruent", height(data),1)
]);

TST_dev = [data.TST_dev; data.TST_dev; data.TST_dev; data.TST_dev];

data_long = table(ID, RT, Switch, Congruency, TST_dev);

%% 4. Set reference levels explicitly
data_long.Switch = reordercats(data_long.Switch, {'repeat','switch'});
data_long.Congruency = reordercats(data_long.Congruency, {'congruent','incongruent'});

%% 5. Run mixed model
lme = fitlme(data_long, ...
    'RT ~ 1 + Switch*Congruency + Switch*TST_dev + Congruency*TST_dev + Switch:Congruency:TST_dev + (1|ID)');

%% 6. Output
disp('Mixed model (RT ~ TST_dev) complete.')
disp(lme)

%% 6.5 Create rounded results table and write .txt file
outTbl = table( ...
    string(lme.Coefficients.Name), ...
    round(lme.Coefficients.Estimate, 3), ...
    round(lme.Coefficients.SE, 3), ...
    round(lme.Coefficients.tStat, 3), ...
    round(lme.Coefficients.pValue, 4), ...
    'VariableNames', {'Effect','Estimate','SE','t','p'});

txtFile = '\\hypatia.uio.no\...\mixed_model_sleep_RT_results.txt';
writetable(outTbl, txtFile, 'Delimiter', '\t', 'FileType', 'text');

%% 7. Save
save('\\hypatia.uio.no\...\mixed_model_sleep_RT.mat', ...
    'lme', 'data', 'data_long', 'outTbl');

disp('Mixed model complete.')
disp('Results table saved as .txt')
