%% Script: MIXED_MODEL_TSTSD_THETA_FINAL

% Author: Røskva
% Created: 07.04.2026
% Modified: 24.04.2026
%
% Purpose:
% Examine whether sleep variability (TST SD) predicts theta activity
% across task conditions using a linear mixed-effects model.
%
% Input:
% theta_measures_cycles_3_0p8_winsize1s_3to25.csv
% sleep_measures_for_analysis.csv
%
% Output:
% mixed_model_tstsd_theta_3to25.mat
% mixed_model_tstsd_theta_3to25_results.txt
%
% Notes:
% Theta values are the ROI-averaged values across Fz, FCz, and Cz.
% Data are reshaped into long format (one row per participant x condition).
% The model tests whether sleep variability predicts theta, and whether this
% depends on Switch and/or Congruency.
% TST_sd_h is grand-mean centered so that main effects are interpreted
% at the sample's average sleep variability.

clear; clc;

%% 1. Paths
thetaFile = '\\hypatia.uio.no\...\theta_measures_cycles_3_0p8_winsize1s_3to25.csv';
sleepFile = '\\hypatia.uio.no\...\sleep_measures_for_analysis.csv';
outFile   = '\\hypatia.uio.no\...\mixed_model_tstsd_theta_3to25.mat';

%% 2. Load data
theta = readtable(thetaFile);
sleep = readtable(sleepFile);

%% 3. Harmonize ID column names
if ismember('participant', theta.Properties.VariableNames)
    theta = renamevars(theta, 'participant', 'ID');
end

%% 4. Keep only columns needed from theta
theta = theta(:, {'ID','theta_RC','theta_RI','theta_SC','theta_SI'});

%% 5. Merge theta + sleep
data = innerjoin(theta, sleep, 'Keys', 'ID');

%% 6. Remove missing TST_sd_h or theta values
keep = ~isnan(data.TST_sd_h) & ...
       ~isnan(data.theta_RC) & ~isnan(data.theta_RI) & ...
       ~isnan(data.theta_SC) & ~isnan(data.theta_SI);

data = data(keep,:);

fprintf('Merged N (theta + TST_sd_h): %d\n', height(data));

%% 6.5 Grand-mean center TST_sd_h
grandMean_TSTsd = mean(data.TST_sd_h, 'omitnan');
data.TST_sd_h_c = data.TST_sd_h - grandMean_TSTsd;

fprintf('Grand mean used for centering TST_sd_h: %.4f\n', grandMean_TSTsd);

%% 7. Create long format
ID = [data.ID; data.ID; data.ID; data.ID];

theta_vals = [
    data.theta_RC
    data.theta_RI
    data.theta_SC
    data.theta_SI
];

Switch = categorical([
    repmat("repeat", height(data), 1)
    repmat("repeat", height(data), 1)
    repmat("switch", height(data), 1)
    repmat("switch", height(data), 1)
]);

Congruency = categorical([
    repmat("congruent", height(data), 1)
    repmat("incongruent", height(data), 1)
    repmat("congruent", height(data), 1)
    repmat("incongruent", height(data), 1)
]);

TST_sd_h_c = [data.TST_sd_h_c; data.TST_sd_h_c; data.TST_sd_h_c; data.TST_sd_h_c];

data_long = table(ID, theta_vals, Switch, Congruency, TST_sd_h_c);

%% 8. Set reference levels explicitly
data_long.Switch = reordercats(data_long.Switch, {'repeat','switch'});
data_long.Congruency = reordercats(data_long.Congruency, {'congruent','incongruent'});

%% 9. Mixed model
lme = fitlme(data_long, ...
    'theta_vals ~ 1 + Switch*Congruency + Switch*TST_sd_h_c + Congruency*TST_sd_h_c + Switch:Congruency:TST_sd_h_c + (1|ID)');

%% 10. Output
disp('Mixed model (theta ~ TST_sd_h_c) complete.')
disp(lme)

%% 10.5 Create rounded results table and write .txt file
outTbl = table( ...
    string(lme.Coefficients.Name), ...
    round(lme.Coefficients.Estimate, 3), ...
    round(lme.Coefficients.SE, 3), ...
    round(lme.Coefficients.tStat, 3), ...
    round(lme.Coefficients.pValue, 4), ...
    'VariableNames', {'Effect','Estimate','SE','t','p'});

txtFile = '\\hypatia.uio.no\...\mixed_model_tstsd_theta_3to25_results.txt';
writetable(outTbl, txtFile, 'Delimiter', '\t', 'FileType', 'text');

%% 11. Save
save(outFile, 'lme', 'data', 'data_long', 'outTbl', 'grandMean_TSTsd');

disp('Mixed model saved.')
disp('Results table saved as .txt')
