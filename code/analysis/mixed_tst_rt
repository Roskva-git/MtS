%% Script: MIXED_MODEL_MEANTST_RT

% Author: Røskva 
% Created: 07.04.2026
% Modified: 23.04.2026

% Purpose:
% Examine whether habitual sleep duration predicts reaction times
% across task conditions using a linear mixed-effects model.

% Input:
% data_merged_sleep_behaviour.csv

% Output:
% mixed_model_meantst_RT.mat
% mixed_model_meantst_RT_results.txt

% Notes:
% Data are reshaped into long format (one row per participant x condition).
% The model tests whether habitual sleep (TST_mean_h) predicts RT,
% and whether this depends on Switch and/or Congruency.
% TST_mean_h is grand-mean centered so that main effects are interpreted
% at the sample's average habitual sleep duration.

clear; clc;

%% 1. Load data
data = readtable('\\hypatia.uio.no\...\data_merged_sleep_behaviour.csv');

%% 2. Remove missing values
keep = ~isnan(data.TST_mean_h) & ...
       ~isnan(data.rt_cC_rp_con) & ~isnan(data.rt_cC_rp_inc) & ...
       ~isnan(data.rt_cC_sw_con) & ~isnan(data.rt_cC_sw_inc);

data = data(keep,:);

fprintf('Merged N (RT + TST_mean_h): %d\n', height(data));

%% 2.5 Grand-mean center TST_mean_h
grandMean_TSTmean = mean(data.TST_mean_h, 'omitnan');
data.TST_mean_h_c = data.TST_mean_h - grandMean_TSTmean;

fprintf('Grand mean used for centering TST_mean_h: %.4f\n', grandMean_TSTmean);

%% 3. Create long format
ID = [data.ID; data.ID; data.ID; data.ID];

RT = [
    data.rt_cC_rp_con
    data.rt_cC_rp_inc
    data.rt_cC_sw_con
    data.rt_cC_sw_inc
];

Switch = categorical([
    repmat("repeat", height(data),1)
    repmat("repeat", height(data),1)
    repmat("switch", height(data),1)
    repmat("switch", height(data),1)
]);

Congruency = categorical([
    repmat("congruent", height(data),1)
    repmat("incongruent", height(data),1)
    repmat("congruent", height(data),1)
    repmat("incongruent", height(data),1)
]);

TST_mean_h_c = [data.TST_mean_h_c; data.TST_mean_h_c; data.TST_mean_h_c; data.TST_mean_h_c];

data_long = table(ID, RT, Switch, Congruency, TST_mean_h_c);

%% 4. Set reference levels explicitly
data_long.Switch = reordercats(data_long.Switch, {'repeat','switch'});
data_long.Congruency = reordercats(data_long.Congruency, {'congruent','incongruent'});

%% 5. Run mixed model
lme = fitlme(data_long, ...
    'RT ~ 1 + Switch*Congruency + Switch*TST_mean_h_c + Congruency*TST_mean_h_c + Switch:Congruency:TST_mean_h_c + (1|ID)');

%% 6. Output
disp('Mixed model (RT ~ TST_mean_h_c) complete.')
disp(lme)

%% 6.5 Create rounded results table and write .txt file
outTbl = table( ...
    string(lme.Coefficients.Name), ...
    round(lme.Coefficients.Estimate, 3), ...
    round(lme.Coefficients.SE, 3), ...
    round(lme.Coefficients.tStat, 3), ...
    round(lme.Coefficients.pValue, 4), ...
    'VariableNames', {'Effect','Estimate','SE','t','p'});

txtFile = '\\hypatia.uio.no\...\mixed_model_meantst_RT_results.txt';
writetable(outTbl, txtFile, 'Delimiter', '\t', 'FileType', 'text');

%% 7. Save
save('\\hypatia.uio.no\...\mixed_model_meantst_RT.mat', ...
    'lme', 'data', 'data_long', 'outTbl', 'grandMean_TSTmean');

disp('Mixed model saved.')
disp('Results table saved as .txt')
