%% Script: anova_omissions
% Author: Røskva
% Created: 06.04.2026
% Modified: 06.04.2026

% Purpose:
% Run a 2×2 repeated-measures ANOVA on omission rates
% with within-subject factors switch (repeat vs switch)
% and congruency (congruent vs incongruent).

% Input:
% behavioural_overview_master.csv
% (one row per participant, omission counts per condition)

% Output:
% anova_omit_results.mat (ANOVA table)

% Notes:
% Omission is defined as number of missed responses per condition.
% Conditions:
% repeat–congruent, repeat–incongruent, switch–congruent, switch–incongruent.

clear; clc;

%% 1. Paths
inFile  = '\\hypatia.uio.no\lh-sv-psi\MICC\Projects\MindTheSleep\Projects\Røskva\Data\TST\4_behavioural\behavioural_overview_master.csv';
outFile = '\\hypatia.uio.no\lh-sv-psi\MICC\Projects\MindTheSleep\Projects\Røskva\Data\TST\ANOVA\anova_omit_results.mat';

%% 2. Load data
T = readtable(inFile);

%% 3. Compute omission rates per condition
omit_rp_con = (T.n_rp_con - T.acc_rp_con .* T.n_rp_con) ./ T.n_rp_con;
omit_rp_inc = (T.n_rp_inc - T.acc_rp_inc .* T.n_rp_inc) ./ T.n_rp_inc;
omit_sw_con = (T.n_sw_con - T.acc_sw_con .* T.n_sw_con) ./ T.n_sw_con;
omit_sw_inc = (T.n_sw_inc - T.acc_sw_inc .* T.n_sw_inc) ./ T.n_sw_inc;

%% 4. Create matrix (order: RC, RI, SC, SI)
Y = [
    omit_rp_con ...
    omit_rp_inc ...
    omit_sw_con ...
    omit_sw_inc
];

Y = array2table(Y, 'VariableNames', {'RC','RI','SC','SI'});

%% 5. Define within-subject factors
Switch = categorical({'repeat';'repeat';'switch';'switch'});
Congruency = categorical({'con';'inc';'con';'inc'});

within = table(Switch, Congruency);

%% 6. Run repeated-measures ANOVA
rm = fitrm(Y, 'RC-SI ~ 1', 'WithinDesign', within);
ranovatbl = ranova(rm, 'WithinModel', 'Switch*Congruency');

%% 7. Display results
disp('Omission ANOVA results:')
disp(ranovatbl)

%% 8. Save results
save(outFile, 'ranovatbl')
